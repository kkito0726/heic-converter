{
  "name": "heic-converter",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.26.4"
    }
  },
  "containerEnv": {
    "CGO_ENABLED": "0"
  },
  "postCreateCommand": "go mod download",
  "customizations": {
    "vscode": {
      "extensions": ["golang.go"]
    }
  }
}
